{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"layout": {
			"contentSize": "760px",
			"wideSize": "1280px"
		},
		"color": {
			"palette": [
				{ "slug": "primary",           "color": "#1A1A1A", "name": "Primary" },
				{ "slug": "accent",            "color": "#B85C38", "name": "Accent" },
				{ "slug": "background-light",  "color": "#F9F9F7", "name": "Background Light" },
				{ "slug": "background-dark",   "color": "#121212", "name": "Background Dark" },
				{ "slug": "surface",           "color": "#242424", "name": "Surface" },
				{ "slug": "white",             "color": "#ffffff", "name": "White" }
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "'Outfit', sans-serif",
					"slug": "display",
					"name": "Outfit (Display)"
				},
				{
					"fontFamily": "'Space Grotesk', sans-serif",
					"slug": "logo",
					"name": "Space Grotesk (Logo)"
				}
			],
			"fluid": false
		},
		"spacing": {
			"units": [ "px", "em", "rem", "vh", "vw", "%" ],
			"blockGap": true
		},
		"blocks": {
			"core/paragraph": {
				"typography": { "fontFamily": "'Outfit', sans-serif" }
			},
			"core/heading": {
				"typography": { "fontFamily": "'Outfit', sans-serif" }
			},
			"core/list": {
				"typography": { "fontFamily": "'Outfit', sans-serif" }
			},
			"core/quote": {
				"typography": { "fontFamily": "'Outfit', sans-serif" }
			},
			"core/button": {
				"typography": { "fontFamily": "'Outfit', sans-serif" }
			},
			"core/table": {
				"typography": { "fontFamily": "'Outfit', sans-serif" }
			}
		}
	},
	"styles": {
		"color": {
			"background": "#F9F9F7",
			"text": "#1A1A1A"
		},
		"typography": {
			"fontFamily": "'Outfit', sans-serif",
			"fontSize": "1.0625rem",
			"lineHeight": "1.8"
		},
		"spacing": {
			"blockGap": "1.5rem"
		},
		"elements": {
			"link": {
				"color": { "text": "#B85C38" }
			},
			"h1": {
				"typography": {
					"fontFamily": "'Outfit', sans-serif",
					"fontWeight": "900",
					"lineHeight": "0.95",
					"letterSpacing": "-0.02em"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "'Outfit', sans-serif",
					"fontWeight": "800",
					"lineHeight": "0.95",
					"letterSpacing": "-0.02em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "'Outfit', sans-serif",
					"fontWeight": "700",
					"lineHeight": "1.1"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "'Outfit', sans-serif",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "'Outfit', sans-serif",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "'Outfit', sans-serif",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			}
		},
		"blocks": {
			"core/paragraph": {
				"spacing": { "margin": { "top": "0", "bottom": "1.25em" } }
			},
			"core/heading": {
				"spacing": { "margin": { "top": "2em", "bottom": "0.5em" } }
			},
			"core/image": {
				"spacing": { "margin": { "top": "2rem", "bottom": "2rem" } }
			},
			"core/separator": {
				"color": { "text": "rgba(26,26,26,0.1)" }
			},
			"core/quote": {
				"color": { "text": "rgba(26,26,26,0.6)" },
				"border": { "left": { "color": "#B85C38", "width": "3px" } }
			},
			"core/button": {
				"color": {
					"background": "#1A1A1A",
					"text": "#ffffff"
				},
				"typography": {
					"fontSize": "0.65rem",
					"fontWeight": "700",
					"letterSpacing": "0.2em",
					"textTransform": "uppercase"
				}
			}
		}
	}
}
